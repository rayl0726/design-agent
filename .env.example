# ============================================
# 美陈设计 Agent 系统环境变量
# ============================================

# ---------- Ollama (本地 LLM) ----------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=qwen2.5:14b
OLLAMA_VLM_MODEL=qwen2.5-vl
OLLAMA_EMBEDDING_MODEL=bge-m3

# ---------- Python AI 服务 ----------
PYTHON_AI_HOST=localhost
PYTHON_AI_PORT=8000

# ---------- Java 协调层 ----------
JAVA_ORCHESTRATOR_PORT=8080

# ---------- Milvus (向量数据库) ----------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_CASES=case_descriptions
MILVUS_COLLECTION_IMAGES=image_descriptions

# ---------- SQLite (结构化数据库) ----------
SQLITE_DB_PATH=data/sqlite/meichen.db

# ---------- 图像生成 ----------
POLLINATIONS_BASE_URL=https://image.pollinations.ai
POLLINATIONS_TIMEOUT=60
COMFYUI_BASE_URL=http://localhost:8188

# ---------- 文件存储 ----------
UPLOAD_DIR=data/uploads
IMAGE_CACHE_DIR=data/images
TEMPLATE_DIR=app/templates

# ---------- 文档生成 ----------
PPT_TEMPLATE_PATH=data/templates/template.pptx
